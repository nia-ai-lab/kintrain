[
  {
    "name": "get_recent_gym_visits",
    "description": "指定期間の直近ジム実施履歴を取得する",
    "inputSchema": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "内部利用。Runtime がJWT subを設定する。"
        },
        "days": {
          "type": "integer",
          "description": "何日前まで取得するか（1-365）"
        },
        "limit": {
          "type": "integer",
          "description": "取得件数上限（1-100）"
        }
      },
      "required": ["userId"]
    }
  },
  {
    "name": "get_training_history",
    "description": "特定トレーニングメニューの過去実施履歴を取得する",
    "inputSchema": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "内部利用。Runtime がJWT subを設定する。"
        },
        "trainingMenuItemId": {
          "type": "string",
          "description": "対象トレーニングメニューID"
        },
        "limit": {
          "type": "integer",
          "description": "取得件数上限（1-100）"
        }
      },
      "required": ["userId", "trainingMenuItemId"]
    }
  },
  {
    "name": "get_daily_records",
    "description": "日付範囲のDaily記録を取得する",
    "inputSchema": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "内部利用。Runtime がJWT subを設定する。"
        },
        "from": {
          "type": "string",
          "description": "開始日（YYYY-MM-DD）"
        },
        "to": {
          "type": "string",
          "description": "終了日（YYYY-MM-DD）"
        }
      },
      "required": ["userId"]
    }
  },
  {
    "name": "get_daily_record",
    "description": "指定日のDaily記録を取得する",
    "inputSchema": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "内部利用。Runtime がJWT subを設定する。"
        },
        "date": {
          "type": "string",
          "description": "対象日（YYYY-MM-DD）"
        }
      },
      "required": ["userId", "date"]
    }
  },
  {
    "name": "save_daily_diary",
    "description": "Dailyの日記(diary)を保存する。既存日記がある場合はmode指定で追記または上書きする。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "内部利用。Runtime がJWT subを設定する。"
        },
        "diary": {
          "type": "string",
          "description": "保存する日記本文"
        },
        "date": {
          "type": "string",
          "description": "対象日（YYYY-MM-DD）。未指定時はtimeZoneId基準の本日。"
        },
        "timeZoneId": {
          "type": "string",
          "description": "IANAタイムゾーンID。date未指定時の本日判定に使う。"
        },
        "mode": {
          "type": "string",
          "description": "既存日記がある場合の保存モード。append または overwrite。"
        }
      },
      "required": ["userId", "diary"]
    }
  },
  {
    "name": "get_goal",
    "description": "体重・体脂肪率の目標情報を取得する",
    "inputSchema": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "内部利用。Runtime がJWT subを設定する。"
        }
      },
      "required": ["userId"]
    }
  },
  {
    "name": "get_ai_character_profile",
    "description": "AIコーチキャラクター設定を取得する",
    "inputSchema": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "内部利用。Runtime がJWT subを設定する。"
        }
      },
      "required": ["userId"]
    }
  },
  {
    "name": "save_advice_log",
    "description": "生成したアドバイスの監査ログを保存する",
    "inputSchema": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "内部利用。Runtime がJWT subを設定する。"
        },
        "requestId": {
          "type": "string",
          "description": "Runtime側要求ID"
        },
        "advice": {
          "type": "string",
          "description": "保存するアドバイス本文"
        }
      },
      "required": ["userId", "advice"]
    }
  },
  {
    "name": "create_training_menu_set_from_ai",
    "description": "AI提案から新規トレーニングメニューセットと新規トレーニングメニュー項目を登録する。既存セットや既存項目は変更しない。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "内部利用。Runtime がJWT subを設定する。"
        },
        "setName": {
          "type": "string",
          "description": "新規作成するメニューセット名"
        },
        "makeDefault": {
          "type": "boolean",
          "description": "既定セットにするか。既定セットが既に存在する場合は false で使う。"
        },
        "items": {
          "type": "array",
          "description": "新規作成するトレーニングメニュー項目一覧",
          "items": {
            "type": "object",
            "properties": {
              "trainingName": {
                "type": "string"
              },
              "bodyPart": {
                "type": "string"
              },
              "equipment": {
                "type": "string",
                "enum": ["マシン", "フリー", "自重", "その他"]
              },
              "frequency": {
                "type": "integer",
                "minimum": 1,
                "maximum": 8
              },
              "defaultWeightKg": {
                "type": "number"
              },
              "defaultRepsMin": {
                "type": "integer"
              },
              "defaultRepsMax": {
                "type": "integer"
              },
              "defaultSets": {
                "type": "integer"
              },
              "memo": {
                "type": "string"
              }
            },
            "required": [
              "trainingName",
              "equipment",
              "frequency",
              "defaultWeightKg",
              "defaultRepsMin",
              "defaultRepsMax",
              "defaultSets"
            ]
          }
        }
      },
      "required": ["userId", "setName", "items"]
    }
  }
]
